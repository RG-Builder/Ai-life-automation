rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isUnchanged(field) { return incoming()[field] == existing()[field]; }

    // --- ENTITY VALIDATIONS ---
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'created_at'])
        && data.email is string && data.email.size() <= 256
        && (data.get('role', 'user') == 'user') // Users can't self-promote
        && data.created_at is string; // Or timestamp if using serverTimestamp
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'created_at'])
        && data.title is string && data.title.size() <= 200
        && data.status in ['pending', 'completed', 'overdue']
        && data.priority in ['low', 'medium', 'high']
        && data.created_at is string;
    }

    function isValidHabit(data) {
      return data.keys().hasAll(['title', 'created_at'])
        && data.title is string && data.title.size() <= 200
        && data.created_at is string;
    }

    // --- COLLECTION RULES ---

    // /users/{userId}
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow list: if false;
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lifeScore', 'streak', 'onboardingComplete', 'wakeTime', 'directive', 'subscription_plan'])
        && isUnchanged('email')
        && isUnchanged('role')
        && isUnchanged('created_at')
      );

      // /users/{userId}/tasks/{taskId}
      match /tasks/{taskId} {
        allow get, list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(taskId) && isValidTask(incoming());
        
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(taskId) && isValidTask(incoming()) && (
          // Action: Complete
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'completed_at']) && incoming().status == 'completed') ||
          // Action: Edit
          (incoming().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'priority', 'deadline', 'duration', 'category', 'impact', 'urgency', 'importance', 'is_habit']))
        );
        
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(taskId);
      }

      // /users/{userId}/habits/{habitId}
      match /habits/{habitId} {
        allow get, list: if isOwner(userId) && isValidId(userId);
        
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(habitId) && isValidHabit(incoming());
        
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(habitId) && isValidHabit(incoming()) && (
          // Action: Toggle completion
          incoming().diff(existing()).affectedKeys().hasOnly(['last_completed_at', 'current_count', 'streak']) ||
          // Action: Edit
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'frequency', 'goal_count', 'category'])
        );
        
        allow delete: if isOwner(userId) && isValidId(userId) && isValidId(habitId);
      }

      // /users/{userId}/motivation/state
      match /motivation/state {
        allow get: if isOwner(userId) && isValidId(userId);
        allow write: if isOwner(userId) && isValidId(userId);
      }

      // /users/{userId}/daily_scores/{date}
      match /daily_scores/{date} {
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create, update: if isOwner(userId) && isValidId(userId);
      }

      // /users/{userId}/reminder_logs/{logId}
      match /reminder_logs/{logId} {
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow create: if isOwner(userId) && isValidId(userId) && isValidId(logId);
        allow update: if isOwner(userId) && isValidId(userId) && isValidId(logId) && incoming().diff(existing()).affectedKeys().hasOnly(['action_taken']);
      }

      // /users/{userId}/payments/{paymentId}
      match /payments/{paymentId} {
        allow get, list: if isOwner(userId) && isValidId(userId);
        allow write: if isOwner(userId) && isValidId(userId) && isValidId(paymentId);
      }
    }
    
    // Connection test doc
    match /_connection_test_/init {
      allow get: if isSignedIn();
    }
  }
}
